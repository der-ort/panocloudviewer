{
  "name": "@der-ort/pano-cloud-viewer-core",
  "version": "0.1.0",
  "description": "Headless point-cloud engine (Three.js managers, adapters, types) — no React, no UI",
  "author": "der-ort",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "dependencies": {
    "potree-core": "^2.0.15"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "three": "^0.170.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
